# You can find a list of all available environment variables in
# https://github.com/Chocobozzz/BoomBoom/blob/master/support/docker/production/config/custom-environment-variables.yaml


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

POSTGRES_USER=<MY POSTGRES USERNAME>
POSTGRES_PASSWORD=<MY POSTGRES PASSWORD>
# Postgres database name "boomboom"
POSTGRES_DB=boomboom
# The database name used by BoomBoom will be BOOMBOOM_DB_NAME (only if set) *OR* 'boomboom'+BOOMBOOM_DB_SUFFIX
#BOOMBOOM_DB_NAME=<MY POSTGRES DB NAME>
#BOOMBOOM_DB_SUFFIX=_prod
# Database username and password used by BoomBoom must match Postgres', so they are copied:
BOOMBOOM_DB_USERNAME=$POSTGRES_USER
BOOMBOOM_DB_PASSWORD=$POSTGRES_PASSWORD
BOOMBOOM_DB_SSL=false
# Default to Postgres service name "postgres" in docker-compose.yml
BOOMBOOM_DB_HOSTNAME=postgres


# -----------------------------------------------------------------------------
# BoomBoom Network And Secrets
# -----------------------------------------------------------------------------

# If you test BoomBoom in local: use "boomboom.localhost" and add this domain to your host file resolving on 127.0.0.1
BOOMBOOM_WEBSERVER_HOSTNAME=<MY DOMAIN>
# If you just want to test BoomBoom on local
#BOOMBOOM_WEBSERVER_PORT=9000
#BOOMBOOM_WEBSERVER_HTTPS=false

# If you need more than one IP as trust_proxy
# pass them as a comma separated array:
BOOMBOOM_TRUST_PROXY=["127.0.0.1", "loopback", "172.18.0.0/16"]

# Generate one using `openssl rand -hex 32`
BOOMBOOM_SECRET=<MY BOOMBOOM SECRET>


# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------

# E-mail configuration
# If you use a Custom SMTP server
#BOOMBOOM_SMTP_USERNAME=
#BOOMBOOM_SMTP_PASSWORD=
# Default to Postfix service name "postfix" in docker-compose.yml
# May be the hostname of your Custom SMTP server
BOOMBOOM_SMTP_HOSTNAME=postfix
BOOMBOOM_SMTP_PORT=25
BOOMBOOM_SMTP_FROM=noreply@<MY DOMAIN>
BOOMBOOM_SMTP_TLS=false
BOOMBOOM_SMTP_DISABLE_STARTTLS=false
BOOMBOOM_ADMIN_EMAIL=<MY EMAIL ADDRESS>


# -----------------------------------------------------------------------------
# Postfix
# -----------------------------------------------------------------------------

# Postfix service configuration
POSTFIX_myhostname=<MY DOMAIN>
# If you need to generate a list of sub/DOMAIN keys
# pass them as a whitespace separated string <DOMAIN>=<selector>
OPENDKIM_DOMAINS=<MY DOMAIN>=boomboom
# see https://github.com/wader/postfix-relay/pull/18
OPENDKIM_RequireSafeKeys=no


# -----------------------------------------------------------------------------
# Object Storage (Optional)
# -----------------------------------------------------------------------------

# If you want to enable object storage for BoomBoom, set the following variables.
#BOOMBOOM_OBJECT_STORAGE_ENABLED=
#BOOMBOOM_OBJECT_STORAGE_ENDPOINT=
#BOOMBOOM_OBJECT_STORAGE_REGION=
#BOOMBOOM_OBJECT_STORAGE_FORCE_PATH_STYLE=
#BOOMBOOM_OBJECT_STORAGE_CREDENTIALS_ACCESS_KEY_ID=
#BOOMBOOM_OBJECT_STORAGE_CREDENTIALS_SECRET_ACCESS_KEY=
#BOOMBOOM_OBJECT_STORAGE_STREAMING_PLAYLISTS_BUCKET_NAME=
#BOOMBOOM_OBJECT_STORAGE_STREAMING_PLAYLISTS_PREFIX=
#BOOMBOOM_OBJECT_STORAGE_STREAMING_PLAYLISTS_BASE_URL=
#BOOMBOOM_OBJECT_STORAGE_WEB_VIDEOS_BUCKET_NAME=
#BOOMBOOM_OBJECT_STORAGE_WEB_VIDEOS_PREFIX=
#BOOMBOOM_OBJECT_STORAGE_WEB_VIDEOS_BASE_URL=
#BOOMBOOM_OBJECT_STORAGE_USER_EXPORTS_BUCKET_NAME=
#BOOMBOOM_OBJECT_STORAGE_USER_EXPORTS_PREFIX=
#BOOMBOOM_OBJECT_STORAGE_USER_EXPORTS_BASE_URL=
#BOOMBOOM_OBJECT_STORAGE_ORIGINAL_VIDEO_FILES_BUCKET_NAME=
#BOOMBOOM_OBJECT_STORAGE_ORIGINAL_VIDEO_FILES_PREFIX=
#BOOMBOOM_OBJECT_STORAGE_ORIGINAL_VIDEO_FILES_BASE_URL=
#BOOMBOOM_OBJECT_STORAGE_CAPTIONS_BUCKET_NAME=
#BOOMBOOM_OBJECT_STORAGE_CAPTIONS_PREFIX=
#BOOMBOOM_OBJECT_STORAGE_CAPTIONS_BASE_URL=

# Comment these variables if your S3 provider does not support object ACL
BOOMBOOM_OBJECT_STORAGE_UPLOAD_ACL_PUBLIC="public-read"
BOOMBOOM_OBJECT_STORAGE_UPLOAD_ACL_PRIVATE="private"


# -----------------------------------------------------------------------------
# Outbound Proxies (Optional)
# -----------------------------------------------------------------------------
# These proxies affect all outbound BoomBoom HTTP(S) traffic, including yt-dlp.
# This is different from the reverse proxy in front of BoomBoom.
#HTTP_PROXY=http://username:password@proxy.example:3128
#HTTPS_PROXY=http://username:password@proxy.example:3128


# -----------------------------------------------------------------------------
# HTTP Video Imports (Optional)
# -----------------------------------------------------------------------------
#BOOMBOOM_IMPORT_VIDEOS_HTTP=true
#BOOMBOOM_IMPORT_VIDEOS_HTTP_YOUTUBE_DL_RELEASE_URL=https://api.github.com/repos/yt-dlp/yt-dlp/releases
#BOOMBOOM_IMPORT_VIDEOS_HTTP_YOUTUBE_DL_RELEASE_NAME=yt-dlp
#BOOMBOOM_IMPORT_VIDEOS_HTTP_FORCE_IPV4=true
# Dedicated outbound proxy pool for HTTP imports. BoomBoom randomly selects one proxy from this list.
# JSON array. Example: ["http://user:pass@proxy-1:3128","http://user:pass@proxy-2:3128"]
#BOOMBOOM_IMPORT_VIDEOS_HTTP_PROXIES=[]
# Enable this to pass cookies to yt-dlp. This can help when imports need a real browser session or when your server IP is limited.
# Only enable this if you trust users allowed to trigger imports because BoomBoom will import using the account from which these cookies were exported.
# That account may be rate limited or temporarily blocked.
# Put your Netscape-format cookies in /data/tmp-persistent/youtube-cookies.txt.
# See https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp for cookie export instructions.
# See https://docs.joinboomboom.org/maintain/configuration#cookies-for-youtube-imports for BoomBoom-specific setup.
#BOOMBOOM_IMPORT_VIDEOS_HTTP_COOKIES_ENABLED=false


# -----------------------------------------------------------------------------
# Logging (Optional)
# -----------------------------------------------------------------------------

#BOOMBOOM_LOG_LEVEL=info
